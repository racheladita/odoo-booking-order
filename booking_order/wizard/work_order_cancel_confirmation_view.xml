<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_work_order_cancel_confirmation" model="ir.ui.view">
        <field name="name">work.order.cancel.confirmation</field>
        <field name="model">work.order.cancel.confirmation</field>
        <field name="arch" type="xml">
            <form string="Reason for Cancellation">
                <group>
                    <p>
                        Please provide a reason for canceling this work order.
                    </p>
                </group>
                <group>
                    <field name="reason" string="Reason" nolabel="1" required="1"/>
                </group>
                <footer>
                    <button name="process" string="Submit" type="object" class="oe_highlight"/>
                    <button string="_Cancel" class="btn-default" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
